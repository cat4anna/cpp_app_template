pipeline {
    agent any
    environment {
        APP_NAME = "cpp_app_template"
        DOCKER_TAG = "${APP_NAME}:alpine"
        DOCKER_REUSE_DAYS=30
    }
    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }
        stage('Build test docker') {
            steps {
                sh "/bin/bash ci/docker_build.sh ${DOCKER_TAG} dockerfile.alpine"
            }
        }
        stage('Build and Test') {
            parallel {
                stage('Debug') {
                    agent {
                        docker {
                            image "${DOCKER_TAG}"
                            reuseNode true
                        }
                    }
                    steps {
                        sh '/usr/bin/lua5.4 ci/ci_run.lua all-debug'
                    }
                }
                stage('Release') {
                    agent {
                        docker {
                            image "${DOCKER_TAG}"
                            reuseNode true
                        }
                    }
                    steps {
                        sh '/usr/bin/lua5.4 ci/ci_run.lua all-release'
                    }
                }
            }
        }
        stage('Archive artifacts') {
            steps {
                archiveArtifacts artifacts: '**/Artifacts/*', followSymlinks: false
                scanForIssues sourceCodeRetention: 'LAST_BUILD', tool: clang()
                xunit checksName: '', thresholds: [failed(unstableThreshold: '0')], tools: [
                    GoogleTest(excludesPattern: 'build/*release/Testing/*ut.xml', pattern: 'build/*/Testing/*ut.xml', stopProcessingIfError: true)]
                benchmark(
                    altInputSchemaLocation: '',
                    altInputSchema: '''{
                        "description": "Google Benchmark JSON schema",
                        "failure": { "value": true },
                        "type": "object",
                        "properties": {
                            "benchmarks": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "name": { "type": "name" },
                                        "real_time": { "type": "result" },
                                        "cpu_time": { "type": "result" },
                                        "iterations": { "type": "parameter" }
                                    }
                                }
                            }
                        }
                    }''',
                    inputLocation: 'build/*release/Testing/*benchmark.json',
                    schemaSelection: 'customSchema',
                    // thresholds: [[$class: 'PercentageThreshold', percentage: 1.0, testGroup: '', testName: 'cpu_time']],
                    truncateStrings: false
                )
            }
        }
    }
}
